# ================================================================================================
# 🏗️ PROJECT-SPECIFIC CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-batcher
# Load Order: 90 (loaded after all default/tool configs, overrides earlier values)
#
# This file contains configuration specific to this project that differs from
# the defaults defined in earlier env files (00-core, 10-*, 20-*).
#
# Only include variables here that need to override defaults.
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Primary Go version for builds and primary test runner
GO_PRIMARY_VERSION=1.25.x

# Secondary Go version for compatibility testing
GO_SECONDARY_VERSION=1.25.x

# MAGE-X Go version overrides
MAGE_X_GO_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE PROVIDER CONFIGURATION
# ================================================================================================

# Coverage Provider Selection (overrides default: internal → codecov)
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration
CODECOV_TOKEN_REQUIRED=true

# ================================================================================================
# 🚫 COVERAGE EXCLUSIONS (aligned with codecov.yml ignore paths)
# ================================================================================================

# Coverage path exclusions matching codecov.yml ignore list plus standard exclusions
GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,testing/,test/,vendor/,testdata/,plans/,docs/

# ================================================================================================
# 🛡️ NANCY CVE EXCLUSIONS
# ================================================================================================

# Nancy CVE Exclusions (overrides the placeholder default in 10-security.env).
# Format: comma-separated CVE IDs, fed to `nancy sleuth --exclude-vulnerability`.
#
# These are transitive (indirect) dependencies pulled in by upstream modules, not
# direct requires in go.mod, so bumping go.mod versions does not resolve them. They
# are excluded until the upstream chain ships fixed releases.
#
# golang.org/x/crypto@v0.51.0 (13 advisories):
#   CVE-2024-45337,CVE-2026-39827,CVE-2026-39828,CVE-2026-39829,CVE-2026-39830,
#   CVE-2026-39831,CVE-2026-39832,CVE-2026-39833,CVE-2026-39834,CVE-2026-42508,
#   CVE-2026-46595,CVE-2026-46597,CVE-2026-46598
# golang.org/x/net@v0.48.0 (6 advisories):
#   CVE-2026-25680,CVE-2026-25681,CVE-2026-27136,CVE-2026-39821,CVE-2026-42502,CVE-2026-42506
NANCY_EXCLUDES=CVE-2024-45337,CVE-2026-39827,CVE-2026-39828,CVE-2026-39829,CVE-2026-39830,CVE-2026-39831,CVE-2026-39832,CVE-2026-39833,CVE-2026-39834,CVE-2026-42508,CVE-2026-46595,CVE-2026-46597,CVE-2026-46598,CVE-2026-25680,CVE-2026-25681,CVE-2026-27136,CVE-2026-39821,CVE-2026-42502,CVE-2026-42506
